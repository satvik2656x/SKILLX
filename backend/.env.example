# SKILLX Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ==================== DATABASE ====================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skillx_db

# ==================== JWT & AUTHENTICATION ====================
# Secret key for JWT token signing (generate a strong random string)
# Recommended: Use `openssl rand -base64 32` to generate
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ==================== CLOUDINARY (Video Upload) ====================
# Cloudinary cloud name (from your Cloudinary dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key (from your Cloudinary dashboard)
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API secret (from your Cloudinary dashboard)
CLOUDINARY_API_SECRET=your_api_secret

# ==================== EMAIL (Nodemailer for OTP) ====================
# Gmail or other email service
# For Gmail with 2FA, use an App Password instead of regular password
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_email_password

# SMTP host (optional, defaults to Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ==================== GOOGLE OAUTH ====================
# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==================== FRONTEND URL ====================
# Frontend URL for OAuth redirects and CORS
FRONTEND_URL=http://localhost:5173

# ==================== SERVER ====================
# Server port
PORT=3001

# Environment (development or production)
NODE_ENV=development

# ==================== OPTIONAL: AWS S3 (Alternative to Cloudinary) ====================
# If using S3 instead of Cloudinary:
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=skillx-videos
